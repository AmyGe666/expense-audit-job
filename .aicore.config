apiVersion: ai.sap.com/v1alpha1
kind: Executable
metadata:
  name: expense-audit-job
  labels:
    scenarios.ai.sap.com/id: expense-audit
    ai.sap.com/version: "1.0.0"
  annotations:
    scenarios.ai.sap.com/name: "expense-audit"
    scenarios.ai.sap.com/description: "Expense Audit Job - Automated expense 审计"

spec:
  image: ghcr.io/amyge666/expense-audit-job:main
  command:
    - python
    - app/main.py

  resources:
    limits:
      cpu: "1"
      memory: "2Gi"
    requests:
      cpu: "500m"
      memory: "1Gi"

  env:
    - name: HANA_HOST
      valueFrom:
        secretKeyRef:
          name: hana-credentials
          key: host

    - name: HANA_PORT
      valueFrom:
        secretKeyRef:
          name: hana-credentials
          key: port

    - name: HANA_USER
      valueFrom:
        secretKeyRef:
          name: hana-credentials
          key: user

    - name: HANA_PASSWORD
      valueFrom:
        secretKeyRef:
          name: hana-credentials
          key: password

    - name: HANA_SCHEMA
      value: "EXPENSE_SCHEMA"

    - name: BATCH_SIZE
      value: "100"